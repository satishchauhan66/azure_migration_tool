                "activities": [
                    {
                        "name": "Append variable1",
                        "type": "AppendVariable",
                        "dependsOn": [],
                        "userProperties": [],
                        "typeProperties": {
                            "variableName": "sample",
                            "value": "test"
                        }
                    }
                ],
                "policy": {
                    "elapsedTimeMetric": {}
